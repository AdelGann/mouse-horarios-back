// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String             @unique @default(uuid())
  user      String             @unique()
  email     String
  password  String
  fullname  String
  img_url   String
  schedules PersonalSchedule[]
  deanery   Deanery            @relation(fields: [deaneryId], references: [id])
  deaneryId String
}

model PersonalSchedule {
  id     String  @unique @default(uuid())
  user   User?   @relation(fields: [userId], references: [id])
  userId String?
  name   String
}

model Schedule {
  id String @unique @default(uuid())
}

model Subject {
  id        String   @unique @default(uuid())
  name      String
  days      String[]
  timetable String[]
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id])
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
}

model Teacher {
  id       String    @unique @default(uuid())
  name     String
  subjects Subject[]
}

model Section {
  id       String    @unique @default(uuid())
  name     String
  subjects Subject[]
}

model Deanery {
  id    String @unique @default(uuid())
  name  String
  users User[]
}
