// schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  email    String  @unique
  password String
  fullname String?
  img_url  String?
  semester Int?
  role     Role    @default(USER)

  schedules PersonalSchedule[]

  deaneryId String
  deanery   Deanery @relation(fields: [deaneryId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model PersonalSchedule {
  id     String  @id @default(uuid())
  name   String
  pdfUrl String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subjects Subject[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model AcademicTerm {
  id        String    @id @default(uuid())
  name      String    @unique
  startDate DateTime?
  endDate   DateTime?

  schedules Schedule[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Schedule {
  id          String  @id @default(uuid())
  semester    Int
  globalQuota Int?
  pdfUrl      String?
  isPublished Boolean @default(false)

  termId String
  term   AcademicTerm @relation(fields: [termId], references: [id])

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  subjects Subject[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Course {
  id       String @id @default(uuid())
  name     String
  semester Int

  careerId String
  career   Career @relation(fields: [careerId], references: [id])

  subjects Subject[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Subject {
  id String @id @default(uuid())

  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  personalSchedules PersonalSchedule[]
  slots             ClassSlot[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Room {
  id       String @id @default(uuid())
  name     String
  capacity Int?

  slots ClassSlot[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ClassSlot {
  id        String @id @default(uuid())
  dayOfWeek Int
  startTime String
  endTime   String

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Teacher {
  id       String    @id @default(uuid())
  name     String
  subjects Subject[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Section {
  id        String     @id @default(uuid())
  name      String
  schedules Schedule[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Deanery {
  id      String   @id @default(uuid())
  name    String
  users   User[]
  careers Career[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Career {
  id   String @id @default(uuid())
  name String

  deaneryId String
  deanery   Deanery @relation(fields: [deaneryId], references: [id])

  courses Course[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  username  String?
  action    String   // e.g. "CREATE_CAREER", "DELETE_SUBJECT", "LOGIN"
  details   String   // details text
  ipAddress String?
  createdAt DateTime @default(now())
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
